PACKAGE_NAME="mudaq"
PACKAGE_VERSION="@VERSION@"
BUILT_MODULE_NAME[0]="mudaq"
DEST_MODULE_LOCATION[0]="/updates/dkms"
AUTOINSTALL="yes"
MAKE[0]="make KERNELRELEASE=${kernelver} KERNELDIR=/lib/modules/${kernelver}/build"
CLEAN="make KERNELRELEASE=${kernelver} KERNELDIR=/lib/modules/${kernelver}/build clean"
