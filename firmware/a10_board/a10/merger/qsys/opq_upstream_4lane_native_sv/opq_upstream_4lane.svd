<?xml version="1.0" encoding="utf-8"?>
        <device schemaVersion="1.3" xmlns:xs="http://www.w3.org/2001/XMLSchema-instance" xs:noNamespaceSchemaLocation="CMSIS-SVD.xsd">
          <name>OPQ_UPSTREAM_4LANE</name>
          <version>26.4.14.0428</version>
          <description>Ordered priority queue runtime CSR aperture for the MuSiP SWB integration.</description>
          <addressUnitBits>8</addressUnitBits>
          <width>32</width>
          <peripherals>
            <peripheral>
              <name>OPQ</name>
              <description>Ordered priority queue CSR window accessed through the Platform Designer JTAG Avalon master.</description>
              <baseAddress>0x00000000</baseAddress>
              <addressBlock>
                <offset>0x0</offset>
                <size>0x400</size>
                <usage>registers</usage>
              </addressBlock>
              <registers>
                <register>
          <name>UID</name>
          <description>Immutable Mu3e IP identifier. Default ASCII &quot;OPQM&quot;.</description>
          <addressOffset>0x000</addressOffset>
          <size>32</size>
          <access>read-only</access>
          <resetValue>0x4F50514D</resetValue>
      <fields>
<field>
  <name>VALUE</name>
  <description>ASCII &quot;OPQM&quot; packed as 0x4F50514D.</description>
  <bitOffset>0</bitOffset>
  <bitWidth>32</bitWidth>
  <access>read-only</access>
</field>
      </fields>
        </register>

        <register>
          <name>META</name>
          <description>Write PAGE_SEL[1:0], then read selected identity payload: 0=VERSION, 1=VERSION_DATE, 2=VERSION_GIT, 3=INSTANCE_ID.</description>
          <addressOffset>0x004</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetValue>0x1A04D1AC</resetValue>
      <fields>
<field>
  <name>PAGE_SEL</name>
  <description>Selects the META payload page on write.</description>
  <bitOffset>0</bitOffset>
  <bitWidth>2</bitWidth>
  <access>read-write</access>
</field>
      </fields>
        </register>

        <register>
          <name>LANE_MASK</name>
          <description>Runtime packet-boundary lane mask. A set bit disables new packets on that lane after the current packet drains.</description>
          <addressOffset>0x008</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
      <fields>
<field>
  <name>MASK_LANE0</name>
  <description>Mask ingress lane 0 at packet boundaries when set.</description>
  <bitOffset>0</bitOffset>
  <bitWidth>1</bitWidth>
  <access>read-write</access>
</field>

<field>
  <name>MASK_LANE1</name>
  <description>Mask ingress lane 1 at packet boundaries when set.</description>
  <bitOffset>1</bitOffset>
  <bitWidth>1</bitWidth>
  <access>read-write</access>
</field>

<field>
  <name>MASK_LANE2</name>
  <description>Mask ingress lane 2 at packet boundaries when set.</description>
  <bitOffset>2</bitOffset>
  <bitWidth>1</bitWidth>
  <access>read-write</access>
</field>

<field>
  <name>MASK_LANE3</name>
  <description>Mask ingress lane 3 at packet boundaries when set.</description>
  <bitOffset>3</bitOffset>
  <bitWidth>1</bitWidth>
  <access>read-write</access>
</field>
      </fields>
        </register>

        <register>
          <name>CTRL</name>
          <description>Control pulses. Write CLEAR_COUNTERS=1 to clear all software-visible counters.</description>
          <addressOffset>0x00C</addressOffset>
          <size>32</size>
          <access>write-only</access>
          <resetValue>0x00000000</resetValue>
      <fields>
<field>
  <name>CLEAR_COUNTERS</name>
  <description>Write-one pulse clears per-lane and frame-table counters.</description>
  <bitOffset>0</bitOffset>
  <bitWidth>1</bitWidth>
  <access>write-only</access>
</field>
      </fields>
        </register>

        <register>
          <name>STATUS</name>
          <description>Aggregated lane-mask, busy, presenter, and effective-mask status.</description>
          <addressOffset>0x010</addressOffset>
          <size>32</size>
          <access>read-only</access>
          <resetValue>0x00400000</resetValue>
      <fields>
<field>
  <name>LANE_MASK_SHADOW</name>
  <description>Current software-programmed lane mask.</description>
  <bitOffset>0</bitOffset>
  <bitWidth>4</bitWidth>
  <access>read-only</access>
</field>

<field>
  <name>ALLOC_BUSY</name>
  <description>Page allocator is active.</description>
  <bitOffset>16</bitOffset>
  <bitWidth>1</bitWidth>
  <access>read-only</access>
</field>

<field>
  <name>ARBITER_BUSY</name>
  <description>Page-RAM write-port arbiter is active.</description>
  <bitOffset>17</bitOffset>
  <bitWidth>1</bitWidth>
  <access>read-only</access>
</field>

<field>
  <name>PRESENTER_BUSY</name>
  <description>Egress presenter is currently valid.</description>
  <bitOffset>18</bitOffset>
  <bitWidth>1</bitWidth>
  <access>read-only</access>
</field>

<field>
  <name>MASK_EFFECTIVE</name>
  <description>At least one lane is currently blocked by the packet-boundary mask.</description>
  <bitOffset>19</bitOffset>
  <bitWidth>1</bitWidth>
  <access>read-only</access>
</field>

<field>
  <name>N_LANE</name>
  <description>Instantiated lane count.</description>
  <bitOffset>20</bitOffset>
  <bitWidth>4</bitWidth>
  <access>read-only</access>
</field>
      </fields>
        </register>

        <register>
          <name>CAP</name>
          <description>Capability summary and per-lane CSR-region geometry.</description>
          <addressOffset>0x014</addressOffset>
          <size>32</size>
          <access>read-only</access>
          <resetValue>0x0440101F</resetValue>
      <fields>
<field>
  <name>UID_META_HEADER</name>
  <description>Common Mu3e UID + META identity header is implemented.</description>
  <bitOffset>0</bitOffset>
  <bitWidth>1</bitWidth>
  <access>read-only</access>
</field>

<field>
  <name>LANE_MASK_CTRL</name>
  <description>Packet-boundary lane mask control is implemented.</description>
  <bitOffset>1</bitOffset>
  <bitWidth>1</bitWidth>
  <access>read-only</access>
</field>

<field>
  <name>PER_LANE_CNTRS</name>
  <description>Per-lane write/read/drop and credit counters are implemented.</description>
  <bitOffset>2</bitOffset>
  <bitWidth>1</bitWidth>
  <access>read-only</access>
</field>

<field>
  <name>FT_CNTRS</name>
  <description>Frame-table write/read/drop counters are implemented.</description>
  <bitOffset>3</bitOffset>
  <bitWidth>1</bitWidth>
  <access>read-only</access>
</field>

<field>
  <name>DRR_CTRL</name>
  <description>Per-lane DRR allowance programming and live observability are implemented.</description>
  <bitOffset>4</bitOffset>
  <bitWidth>1</bitWidth>
  <access>read-only</access>
</field>

<field>
  <name>LANE_REGION_STRIDE</name>
  <description>Per-lane CSR region stride in 32-bit words.</description>
  <bitOffset>8</bitOffset>
  <bitWidth>8</bitWidth>
  <access>read-only</access>
</field>

<field>
  <name>LANE_REGION_BASE</name>
  <description>Base word address of the per-lane CSR region.</description>
  <bitOffset>16</bitOffset>
  <bitWidth>8</bitWidth>
  <access>read-only</access>
</field>

<field>
  <name>N_LANE</name>
  <description>Instantiated lane count.</description>
  <bitOffset>24</bitOffset>
  <bitWidth>8</bitWidth>
  <access>read-only</access>
</field>
      </fields>
        </register>

<register>
  <name>FT_WR_HDR</name>
  <description>Headers committed into frame-table ownership.</description>
  <addressOffset>0x020</addressOffset>
  <size>32</size>
  <access>read-only</access>
  <resetValue>0x00000000</resetValue>
</register>

<register>
