    {
      "id": "active_workspace_source",
      "status": "informational",
      "detail": "The integrated SWB benches now use the musip-regenerated authentic Qsys wrapper under firmware/a10_board/a10/merger/qsys/opq_upstream_4lane_native_sv/generated/, together with the local integration blocks ingress_egress_adaptor, musip_mux_4_1, and musip_event_builder."
    },
    {
      "id": "merge_enabled_default",
      "status": "closed",
      "detail": "The promoted musip flow now runs with the real integrated merge path enabled by default on OPQ_SOURCE_MODE=upstream_qsys_generated. The former bypass-only workaround and the deprecated local OPQ owner are retired."
    },
    {
      "id": "plain_semantic_dma_check",
      "status": "closed",
      "detail": "The plain replay bench validates DMA payloads at the normalized 64-bit hit level, so the user-visible hit contract remains the signoff target."
    },
    {
      "id": "uvm_per_hit_tracking",
      "status": "closed",
      "detail": "The UVM scoreboard reconstructs hidden hit IDs and 8 ns debug timestamps across ingress, OPQ, and DMA and emits SWB_CHECK_PASS only when the full per-hit contract closes."
    },
    {
      "id": "plain_2env_dma_hit_adapter",
      "status": "closed",
      "detail": "The split OPQ-boundary harness now feeds the downstream DMA scoreboard from the same ingress replay via a stream-beat adapter, so smoke and full 2-env runs close on the same per-hit DMA contract as the integrated path."
    },
    {
      "id": "lane_mask_ingress_fix",
      "status": "closed",
      "detail": "The musip-owned SWB integration now applies feb_enable_mask before ingress_egress_adaptor, so masked FEB lanes no longer leak into the promoted OPQ/DMA hit ledger."
    },
    {
      "id": "dma_done_contract",
      "status": "closed",
      "detail": "musip_event_builder now makes the non-zero payload retirement path explicit, asserts end-of-event on the last payload beat, emits the fixed 128-word padding tail only for launched payloads, and preserves explicit zero-word no-launch semantics."
    },
    {
      "id": "external_upstream_audit",
      "status": "informational",
      "detail": "External upstream signoff_4lane alignment may still be audited separately, but it is not part of the musip-local signoff gate in this workspace."
    },
    {
      "id": "stimulus_field_map_anchored",
      "status": "closed",
      "detail": "Every planned case in DV_BASIC/EDGE/PROF/ERROR/CROSS is anchored on the FEB AvST field map derived from feb_frame_assembly.vhd and Mu3eSpecBook \u00a75.2.6. Deviations are explicitly named fault injections."
    },
    {
      "id": "dv_catalog_expanded",
